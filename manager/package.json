{
    "name": "manager",
    "version": "0.1.0",
    "description": "Interpretive markets framework packaging, pinning, and registration tools",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "tsx ./src/index.ts",
        "pack-framework": "tsx ./src/manual/packFramework.ts",
        "pin-framework": "tsx ./src/manual/pinFramework.ts",
        "register-framework": "tsx ./src/manual/registerFramework.ts",
