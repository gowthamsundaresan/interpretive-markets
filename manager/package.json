        "create-market": "tsx ./src/workflows/createMarket.ts"
    },
    "devDependencies": {
        "@types/node": "^20.12.2",
        "@types/tar": "^6.1.13",
        "tsx": "^4.7.1",
        "typescript": "^5.4.3"
    },
    "dependencies": {
        "dotenv": "^16.4.5",
        "tar": "^7.4.3",
        "viem": "^2.21.0"
    }
