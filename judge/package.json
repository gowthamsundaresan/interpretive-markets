{
	"name": "judge",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc",
		"start": "tsx ./src/index.ts",
		"dev": "tsx watch --clear-screen=false ./src/index.ts",
		"link-shared": "mkdir -p node_modules/@interpretive && ln -sfn ../../../../interpretive-markets-backend/packages/shared node_modules/@interpretive/shared",
		"prepare-deploy": "rm -rf _vendored_shared && cp -r ../../interpretive-markets-backend/packages/shared _vendored_shared && rm -rf _vendored_shared/node_modules _vendored_shared/dist && cp ../script/outputs/sepolia/deployment.json deployment.json",
		"deploy": "npm run prepare-deploy && ecloud compute app deploy --name interpretive-judge --dockerfile Dockerfile --env-file .env --instance-type g1-micro-1v --image-ref gowthamsundaresan/interpretive-judge:latest --log-visibility private --skip-profile --resource-usage-monitoring enable --force"
	},
	"dependencies": {
		"@fastify/env": "^4.4.0",
		"@fastify/rate-limit": "^9.1.0",
		"@layr-labs/ai-gateway-provider": "^1.0.1",
		"ai": "^6.0.0",
		"dotenv": "^16.4.5",
		"fastify": "^4.26.2",
		"fastify-plugin": "^4.5.1",
		"openai": "^4.73.0",
		"tar": "^7.4.3",
		"viem": "^2.21.0"
	},
	"devDependencies": {
		"@types/node": "^20.12.2",
		"@types/tar": "^6.1.13",
		"tsx": "^4.7.1",
		"typescript": "^5.4.3"
	}
}
