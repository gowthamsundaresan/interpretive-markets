{
    "name": "{framework-slug}",
    "version": "0.1.0",
    "description": "",
    "applicableTo": [],
    "model": {
        "id": "z-ai/glm-4.7",
        "sampling": {
            "temperature": 0,
            "topP": 1.0,
            "seed": 0,
            "maxTokens": 2400,
            "reasoningEffort": "medium"
        }
    },
    "evidenceSchema": "schemas/dossier.json",
    "outputSchema": {
        "type": "object",
        "required": ["outcome", "confidence_bps", "driving_tier", "subject_ref", "citations", "rationale_hash"],
        "additionalProperties": true,
        "properties": {
            "outcome": { "type": "integer", "enum": [0, 1, 2] },
            "confidence_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
            "driving_tier": { "type": "integer", "enum": [1, 2, 3] },
            "subject_ref": { "type": "string" },
            "citations": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^dossier://" } },
            "rationale_hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" }
        }
    },
    "roles": {
        "investigator": {
            "prompt": "investigator.md",
            "tools": ["fetch_http"],
            "skills": ["schemas/dossier.json", "judge.md"]
        },
        "judge": { "prompt": "judge.md" }
    }
}
