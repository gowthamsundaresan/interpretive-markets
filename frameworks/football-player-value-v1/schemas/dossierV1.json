{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "PlayerValueDossierV1",
    "description": "Mixed structured + unstructured evidence dossier for player-value resolution. The shape is intentionally permissive: most fields are optional and free-form text is expected. The framework prose (framework.md) is the source of truth for how to weigh dossier contents — this schema only constrains the envelope so judges and watchers can parse it the same way.",
    "type": "object",
    "required": ["asOf", "subjects"],
    "properties": {
        "$schema": {
            "type": "string",
            "format": "uri",
            "description": "Optional self-link to the dossier schema (this file). Lets dossier consumers verify the shape without out-of-band coordination."
        },
        "$framework": {
            "type": "object",
            "description": "Optional pointer to the on-chain framework this dossier is shaped for — id, IPFS uri, slug, version. Establishes provenance.",
            "properties": {
                "id": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
                "ipfs": { "type": "string" },
                "slug": { "type": "string" },
                "version": { "type": "string" }
            }
        },
        "asOf": {
            "type": "string",
            "format": "date",
            "description": "Date the evidence snapshot was taken"
        },
        "subjects": {
            "type": "object",
            "description": "Keyed by player name. Every player referenced in the market question should appear as a key.",
            "additionalProperties": { "$ref": "#/$defs/subject" }
        },
        "context_notes": {
            "type": "string",
            "description": "Optional top-level context about the broader situation (team, season, contending alternatives)."
        },
        "context_sources": {
            "type": "array",
            "description": "Optional links backing the context_notes — same shape as per-item source_url pattern, but at the dossier level.",
            "items": { "$ref": "#/$defs/sourceLink" }
        }
    },
    "$defs": {
        "subject": {
            "type": "object",
            "required": ["club", "position"],
            "properties": {
                "club": { "type": "string" },
                "position": { "type": "string" },
                "age": { "type": "integer", "minimum": 14 },
                "season": { "type": "string" },
                "stats": {
                    "type": "object",
                    "description": "Free-form structured stats. Common keys: season, recent5, trailing12m. Inner fields vary by position — refer to framework.md. A `sources` array of {label,url} may be attached so judges/watchers can trace the upstream stat provider.",
                    "additionalProperties": true
                },
                "on_off_splits": {
                    "type": "object",
                    "description": "TIER 1 (PRIMARY) evidence. Team output with the player on the pitch vs off the pitch. The single most direct measurement of value-to-club. Include sample sizes so the reader can judge significance.",
                    "properties": {
                        "with": {
                            "type": "object",
                            "description": "Team output during the player's on-pitch minutes (or matches started).",
                            "additionalProperties": true
                        },
                        "without": {
                            "type": "object",
                            "description": "Team output during the player's off-pitch minutes (or matches missed).",
                            "additionalProperties": true
                        },
                        "sample": {
                            "type": "object",
                            "description": "Sample sizes for each side (minutes, matches) so the delta can be weighted.",
                            "additionalProperties": true
                        },
                        "delta_summary": { "type": "string" },
                        "sources": {
                            "type": "array",
                            "items": { "$ref": "#/$defs/sourceLink" }
                        }
                    }
                },
                "substitution_patterns": {
                    "type": "object",
                    "description": "TIER 1. How the manager actually uses the player: start rate in big games, removal order when chasing/protecting, late-game introduction as a control move. Managers reveal valuation through choices, not words.",
                    "properties": {
                        "big_game_start_rate": { "type": "number", "minimum": 0, "maximum": 1 },
                        "average_minute_substituted_off": { "type": "number" },
                        "removed_first_when_chasing_pct": { "type": "number" },
                        "protected_when_winning_pct": { "type": "number" },
                        "summary": { "type": "string" },
                        "sources": { "type": "array", "items": { "$ref": "#/$defs/sourceLink" } }
                    }
                },
                "team_share": {
                    "type": "object",
                    "description": "TIER 1. Share-of-team metrics: % of team xG, % progressive passes, % final-third touches. Captures load-bearing without manager spin.",
                    "properties": {
                        "xg_involvement_pct": { "type": "number", "minimum": 0, "maximum": 1 },
                        "goals_pct_of_team": { "type": "number", "minimum": 0, "maximum": 1 },
                        "assists_pct_of_team": { "type": "number", "minimum": 0, "maximum": 1 },
                        "progressive_passes_pct": { "type": "number", "minimum": 0, "maximum": 1 },
                        "final_third_touches_pct": { "type": "number", "minimum": 0, "maximum": 1 },
                        "minutes_share_pct": { "type": "number", "minimum": 0, "maximum": 1 },
                        "summary": { "type": "string" },
                        "sources": { "type": "array", "items": { "$ref": "#/$defs/sourceLink" } }
                    }
                },
                "contract_signals": {
                    "type": "object",
                    "description": "TIER 2. What the club's wallet says (distinct from what the manager says): salary share of total wage bill, release clause, recent contract length, peer-club bids actually received.",
                    "properties": {
                        "salary_pct_of_wage_bill": { "type": "number", "minimum": 0, "maximum": 1 },
                        "release_clause_eur": { "type": "number", "minimum": 0 },
                        "contract_end": { "type": "string" },
                        "recent_bids": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "from_club": { "type": "string" },
                                    "amount_eur": { "type": "number" },
                                    "date": { "type": "string" },
                                    "outcome": { "type": "string" }
                                }
                            }
                        },
                        "summary": { "type": "string" },
                        "sources": { "type": "array", "items": { "$ref": "#/$defs/sourceLink" } }
                    }
                },
                "match_reports": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["date", "excerpt"],
                        "properties": {
                            "date": { "type": "string", "format": "date" },
                            "opponent": { "type": "string" },
                            "competition": { "type": "string" },
                            "excerpt": { "type": "string" },
                            "source": { "type": "string" },
                            "source_url": {
                                "type": "string",
                                "format": "uri",
                                "description": "Upstream URL the excerpt was drawn from. zkTLS proofs (v1) will attest to the response from this URL."
                            }
                        }
                    }
                },
                "manager_quotes": {
                    "type": "array",
                    "description": "TIER 3 (DECORATIVE). Managers have direct conflicts of interest — see framework.md. Include for colour and weak confirmation; never as load-bearing argument.",
                    "items": {
                        "type": "object",
                        "required": ["quote"],
                        "properties": {
                            "date": { "type": "string", "format": "date" },
                            "manager": { "type": "string" },
                            "quote": { "type": "string" },
                            "source": { "type": "string" },
                            "source_url": { "type": "string", "format": "uri" }
                        }
                    }
                },
                "scout_notes": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["note"],
                        "properties": {
                            "author": { "type": "string" },
                            "date": { "type": "string", "format": "date" },
                            "note": { "type": "string" },
                            "source_url": { "type": "string", "format": "uri" }
                        }
                    }
                },
                "valuation_history": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["value_eur"],
                        "properties": {
                            "date": { "type": "string" },
                            "value_eur": { "type": "number", "minimum": 0 },
                            "source": { "type": "string" },
                            "source_url": { "type": "string", "format": "uri" },
                            "note": { "type": "string" }
                        }
                    }
                },
                "context_notes": {
                    "type": "string",
                    "description": "Per-subject context: injury status, contract, tactical role, squad alternatives."
                }
            }
        },
        "sourceLink": {
            "type": "object",
            "required": ["url"],
            "properties": {
                "label": { "type": "string" },
                "url": { "type": "string", "format": "uri" }
            }
        }
    }
}
